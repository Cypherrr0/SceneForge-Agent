            "types adjust camera lens property",
            "types configure camera focal distance"
          ],
          "expected_api": "bpy.types.Camera.lens"
        },
        "op6": {
          "description": "设置物体位置坐标",
          "queries": [
            "types set object location coordinates",
            "types adjust object position vector",
            "types configure object translation"
          ],
          "expected_api": "bpy.types.Object.location"
